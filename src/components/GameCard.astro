---
// src/components/GameCard.astro
interface Props {
  title: string;
  rating: number;
  platform: string;
  image: string;
  href: string;
  description: string;
  pubDate: Date;
}

const { title, rating, platform, image, href, description, pubDate } = Astro.props;

// Formateamos la fecha exactamente al estilo del diseño: "April 26, 2026"
const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
});

// Convertimos la plataforma o género a minúsculas/separado por comas como categoría secundaria
const category = platform.toLowerCase().replace('/', ',');
---

<article class="group flex flex-col w-full bg-transparent">
  <div class="relative aspect-[16/10] w-full rounded-none overflow-hidden mb-5">
    <img 
      src={image} 
      alt={title} 
      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading="lazy"
    />
    
    <div class="absolute bottom-0 left-0 bg-[#38bdf8] text-[#030712] text-[11px] font-bold px-3 py-1 tracking-wide uppercase">
      {formattedDate}
    </div>
  </div>

  <div class="flex flex-col flex-grow">
    <span class="text-xs font-semibold tracking-wider text-slate-500 uppercase mb-2 block">
      {category}, {rating >= 9.5 ? 'masterpiece' : 'review'}
    </span>

    <a href={href} class="block mb-3">
      <h3 class="text-xl md:text-2xl font-bold text-white leading-snug tracking-tight transition-colors duration-300 group-hover:text-cyan-400">
        {title}
      </h3>
    </a>

    <p class="text-slate-400 text-[15px] line-clamp-2 leading-relaxed mb-4">
      {description}
    </p>

    <a href={href} class="inline-flex items-center gap-2 text-xs font-bold text-white uppercase tracking-widest mt-auto group/link">
      <span class="border-b border-transparent group-hover/link:border-cyan-400 transition-all">Read More</span>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-cyan-400 transform transition-transform duration-300 group-hover/link:translate-x-1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </div>
</article>