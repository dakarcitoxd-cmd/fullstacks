---
interface Props {
  title: string;
  rating: number;
  image: string;
  href: string;
  platform: string;
}

const { title, rating, image, href, platform } = Astro.props;
---

<a href={href} class="group bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden hover:border-indigo-500/50 transition-all duration-300 hover:shadow-[0_0_30px_rgba(99,102,241,0.2)]">
  <div class="relative aspect-video overflow-hidden">
    <img 
      src={image} 
      alt={title} 
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
    />
    <div class="absolute top-3 left-3 bg-indigo-600 text-white text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wider">
      {platform}
    </div>
  </div>
  
  <div class="p-5">
    <div class="flex justify-between items-start mb-2">
      <h3 class="text-xl font-bold text-slate-100 group-hover:text-indigo-400 transition-colors leading-tight">
        {title}
      </h3>
      <span class="bg-slate-800 text-indigo-400 font-mono font-bold px-2 py-1 rounded text-sm">
        {rating}/10
      </span>
    </div>
    <p class="text-slate-400 text-sm line-clamp-2">
      Haz clic para leer el análisis completo de este título...
    </p>
  </div>
</a>