---
interface Props {
	title: string;
	description?: string;
}

const { 
  title, 
  description = "Análisis, noticias y reseñas del mundo de los videojuegos" 
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/src/assets/astro.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Gaming Blog</title>
    <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@400;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-slate-950 text-slate-100 font-['Urbanist'] antialiased">
		
    <nav class="p-6 border-b border-slate-800">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <a href="/" class="text-2xl font-bold text-indigo-500">GAMER<span>BLOG</span></a>
        <div class="space-x-6 text-sm uppercase tracking-widest">
          <a href="#" class="hover:text-indigo-400 transition">Noticias</a>
          <a href="#" class="hover:text-indigo-400 transition">Análisis</a>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto p-6">
      <slot />
    </main>

    <footer class="p-10 mt-20 border-t border-slate-800 text-center text-slate-500 text-sm">
      &copy; {new Date().getFullYear()} Gaming Blog. Creado con Astro y Bun.
    </footer>

	</body>
</html>
