---
// src/pages/index.astro
import Layout from '../layouts/MainLayout.astro';
import GameCard from '../components/GameCard.astro';
import { getCollection } from 'astro:content';

const games = await getCollection('blog');
const sortedGames = games.sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Home">
  <div class="max-w-7xl mx-auto px-6 pt-24 pb-16">
    
    <header class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <div>
        <span class="text-xs font-bold tracking-widest text-cyan-400 uppercase block mb-2">
          ■ About AI
        </span>
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-white">
          Check Latest <span class="text-slate-400">News</span>
        </h2>
      </div>
      
      <a href="#" class="border border-slate-800 hover:border-slate-500 text-sm font-bold tracking-wide px-7 py-3 rounded-full transition duration-300 bg-transparent self-start md:self-auto">
        View All News
      </a>
    </header>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-24 pb-16">
      {
        sortedGames.map((game: any) => (
          <GameCard 
            title={game.data.title}
            rating={game.data.rating}
            platform={game.data.platform}
            image={game.data.image}
            description={game.data.description}
            pubDate={game.data.pubDate}
            href={`/blog/${game.id}`}
          />
        ))
      }
    </div>

  </div>
</Layout>